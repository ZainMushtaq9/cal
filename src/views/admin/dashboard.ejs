<div class="mb-8">
    <h1 class="text-3xl font-bold text-brand-dark mb-2">Admin Dashboard</h1>
    <p class="text-slate-600">Manage calculators, view validation logs, and update system configurations.</p>
</div>

<!-- Stats Overview -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 border-l-4 border-l-brand-blue">
        <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-1">Active Calculators</h3>
        <p class="text-3xl font-bold text-slate-800">
            <%= calculators ? calculators.length : 0 %>
        </p>
    </div>
    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 border-l-4 border-l-brand-green">
        <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-1">Formulas Validated</h3>
        <p class="text-3xl font-bold text-slate-800" id="stat-valid">--</p>
    </div>
    <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 border-l-4 border-l-red-500">
        <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-1">Needs Review</h3>
        <p class="text-3xl font-bold text-red-600" id="stat-review">--</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- Left Column: Calculators -->
    <div class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
                <h2 class="font-bold text-lg text-slate-800">Managed Calculators</h2>
                <button class="text-sm bg-brand-blue text-white px-3 py-1.5 rounded hover:bg-blue-700 transition"
                    onclick="triggerValidationAll()">
                    Validate All via Groq
                </button>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr
                            class="bg-slate-50 text-slate-500 text-sm uppercase tracking-wider border-b border-slate-200">
                            <th class="px-6 py-3 font-medium">Name</th>
                            <th class="px-6 py-3 font-medium">Category</th>
                            <th class="px-6 py-3 font-medium">Status</th>
                            <th class="px-6 py-3 font-medium">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100" id="calculators-table">
                        <!-- Populated via AJAX -->
                        <tr>
                            <td colspan="4" class="px-6 py-4 text-center text-slate-500">Loading calculators...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Right Column: Validation Logs -->
    <div class="lg:col-span-1">
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden h-full flex flex-col">
            <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
                <h2 class="font-bold text-lg text-slate-800 flex items-center gap-2">
                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                        </path>
                    </svg>
                    Recent Validation Logs
                </h2>
            </div>
            <div class="p-6 overflow-y-auto flex-grow max-h-[600px]" id="logs-container">
                <!-- Populated via AJAX -->
                <p class="text-sm text-slate-500">Loading logs...</p>
            </div>
        </div>
    </div>
</div>

<% Object.assign(locals, { scripts: `<script src="/js/admin.js">
    </script>` }) %>