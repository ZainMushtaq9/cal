{
  "name": "multi-tool-calculator",
  "version": "1.0.0",
  "description": "A high-performance, SEO-optimized, scalable multi-tool calculator website",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "watch:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "groq-sdk": "^0.3.3",
    "node-cron": "^3.0.3",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "nodemon": "^3.1.13",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  }
}
